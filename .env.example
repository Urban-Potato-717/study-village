# 이 파일을 복사해서 .env 로 이름을 바꾼 뒤 본인 환경에 맞게 값을 수정하세요.
# .env 는 절대 GitHub에 올리지 않습니다 (.gitignore 에 등록되어 있음).

PORT=3000

# MySQL 접속 정보
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=여기에_본인_MySQL_비밀번호
DB_NAME=study_village

# express-session 비밀키 (아무 문자열이나 가능, 길수록 좋음)
SESSION_SECRET=study-village-secret-change-me
