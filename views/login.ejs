<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>로그인 - Study Village</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <h1>로그인</h1>

  <% if (typeof message !== 'undefined' && message && message.length) { %>
    <p class="error"><%= message %></p>
  <% } %>

  <!-- 송정한 담당: action은 POST /auth/login -->
  <form action="/auth/login" method="POST">
    <label>아이디 <input type="text" name="username" required /></label>
    <label>비밀번호 <input type="password" name="password" required /></label>
    <button type="submit">로그인</button>
  </form>

  <p><a href="/auth/register">회원가입</a> | <a href="/">메인으로</a></p>
</body>
</html>
