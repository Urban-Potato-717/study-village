<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>study-village 로그인</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Noto Sans KR', sans-serif;
            background-color: #f6f5f0; 
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        .login-card {
            background-color: #ffffff;
            border-radius: 20px;
            padding: 45px 40px;
            width: 100%;
            max-width: 380px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            box-sizing: border-box;
            text-align: center;
        }
        .logo-area {
            margin-bottom: 35px;
        }
        .logo-icon {
            display: inline-block;
            width: 42px;
            height: 32px;
            border: 3px solid #1c335a;
            border-radius: 4px;
            position: relative;
            margin-bottom: 8px;
        }
        .logo-icon::before {
            content: '';
            position: absolute;
            left: 50%;
            top: 0;
            bottom: 0;
            width: 3px;
            background-color: #bfa15f;
            transform: translateX(-50%);
        }
        .logo-text {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1c335a;
            letter-spacing: -0.5px;
            margin: 0;
        }
        .form-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: #333333;
            text-align: left;
            margin: 0 0 10px 2px;
        }

        /* 추가된 에러 메시지 스타일 (사진 속 빨간 글씨 스타일 정렬) */
        .error-message {
            color: #d11a2a;
            font-size: 0.9rem;
            font-weight: 500;
            text-align: left;
            margin: 0 0 20px 2px;
            animation: fadeIn 0.3s ease;
        }

        .input-group {
            text-align: left;
            margin-bottom: 18px;
        }
        .input-group label {
            display: block;
            font-size: 0.85rem;
            font-weight: 500;
            color: #666666;
            margin-bottom: 6px;
        }
        .input-group input {
            width: 100%;
            padding: 13px 16px;
            border: 1px solid #e0e0e0;
            border-radius: 10px;
            font-size: 0.95rem;
            box-sizing: border-box;
            outline: none;
            background-color: #ffffff;
            transition: all 0.2s ease;
        }
        .input-group input:focus {
            border-color: #279b9b;
            box-shadow: 0 0 0 3px rgba(39, 155, 155, 0.1);
        }
        .btn-login {
            width: 100%;
            padding: 14px;
            background-color: #279b9b;
            color: #ffffff;
            border: none;
            border-radius: 25px;
            font-size: 1rem;
            font-weight: 500;
            cursor: pointer;
            margin-top: 10px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            transition: background-color 0.2s ease;
        }
        .btn-login:hover {
            background-color: #1e7a7a;
        }
        .btn-login svg {
            width: 16px;
            height: 16px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }
        .bottom-links {
            margin-top: 30px;
            font-size: 0.85rem;
            color: #e0e0e0;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 4px;
        }
        .bottom-links a {
            color: #666666;
            text-decoration: none;
            padding: 2px 4px;
        }
        .bottom-links a:hover {
            text-decoration: underline;
            color: #333333;
        }
        .divider {
            color: #ccc;
            user-select: none;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-5px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="logo-area">
            <div class="logo-icon"></div>
            <h1 class="logo-text">study-village</h1>
        </div>

        <h2 class="form-title">로그인</h2>

        <% if (locals.error) { %>
            <div class="error-message"><%= error %></div>
        <% } else if (locals.message) { %>
            <div class="error-message"><%= message %></div>
        <% } %>

        <form action="/auth/login" method="POST">
            <div class="input-group">
                <label for="username">아이디</label>
                <input type="text" id="username" name="username" placeholder="아이디" required>
            </div>
            
            <div class="input-group">
                <label for="password">비밀번호</label>
                <input type="password" id="password" name="password" placeholder="비밀번호" required>
            </div>

            <button type="submit" class="btn-login">
                <svg viewBox="0 0 24 24">
                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1 -2 2h-4M10 17l5-5l-5-5M15 12H3"/>
                </svg>
                로그인
            </button>
        </form>

        <div class="bottom-links">
            <a href="/auth/register">회원가입</a>
            <span class="divider">|</span>
            <a href="/">메인으로 가기</a>
        </div>
    </div>

</body>
</html>