<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>오류 - Study Village</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <h1>오류가 발생했습니다</h1>
  <p><%= message %></p>
  <% if (error && error.stack) { %>
    <pre><%= error.stack %></pre>
  <% } %>
  <p><a href="/">메인으로</a></p>
</body>
</html>
