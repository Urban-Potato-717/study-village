<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>내 공부 기록 - Study Village</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <h1>내 공부 기록</h1>

  <table>
    <thead>
      <tr>
        <th>시작</th>
        <th>종료</th>
        <th>공부 시간(분)</th>
      </tr>
    </thead>
    <tbody>
      <% if (records.length === 0) { %>
        <tr><td colspan="3">아직 기록이 없습니다.</td></tr>
      <% } else { %>
        <% records.forEach(function (r) { %>
          <tr>
            <td><%= new Date(r.start_time).toLocaleString() %></td>
            <td><%= r.end_time ? new Date(r.end_time).toLocaleString() : '공부 중' %></td>
            <td><%= r.study_time ? r.study_time + '분' : '-' %></td>
          </tr>
        <% }); %>
      <% } %>
    </tbody>
  </table>

  <p><a href="/">메인으로</a></p>
</body>
</html>