<!--* 방 안에 들어왔을 때 보는 화면 -->

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title><%= room.name %> - Study Village</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="village-bg">
  <!--! header: 제목 + 네비게이션 (메인/내 기록/내 도감/로그아웃)-->
  <header class="page-header">
    <h1>공부 마을 — <%= room.name %></h1>
    <nav>
      <a href="/">메인</a>
      <a href="/records">내 기록</a>
      <a href="/characters">내 도감</a>
      <a href="/auth/logout">로그아웃</a>
    </nav>
  </header>
  <!--! main.room-Layoyt-->
  <main class="room-layout">
    <!-- 좌석 영역: 3×4 그리드 -->
    <section id="seats" class="seats-grid"
             data-room-id="<%= room.id %>"
             data-user-id="<%= me.id %>"
             data-user-emoji="<%= me.emoji %>"
             data-user-nickname="<%= me.nickname %>">
      <% seats.forEach(function (seat) { %>
        <div class="seat-cell <%= seat.occupied ? 'occupied' : '' %> <%= seat.user && seat.user.isMe ? 'mine' : '' %>"
             data-seat-number="<%= seat.seatNumber %>">
          <div class="seat-emoji">
            <img class="seat-chair" src="/images/tiles/chair.png" alt="좌석" />
            <% if (seat.user) { %>
              <img class="seat-char sprite-img" src="<%= seat.user.imagePath %>" alt=""
                   onerror="this.style.display='none';this.nextElementSibling.style.display='inline-block'" />
              <span class="seat-char sprite-emoji" style="display:none"><%= seat.user.emoji %></span>
            <% } %>
          </div>
          <div class="seat-nick">
            <%= seat.user ? seat.user.nickname : ('좌석 ' + seat.seatNumber) %>
          </div>
          <% if (seat.status) { %>
            <div class="seat-status status-<%= seat.status %>">
              <%= seat.status === 'focusing' ? '집중 중'
                : seat.status === 'resting'  ? '휴식 중'
                : seat.status === 'away'     ? '이탈'
                                             : '대기' %>
            </div>
          <% } %>
        </div>
      <% }); %>
    </section>

    <!-- 사이드바 (방 정보/내 캐릭터 + 시작 종료/알진행도/오늘 기록) -->
    <aside class="sidebar">
      <!-- 입장 실패 등 flash 에러 -->
      <% if (locals.error && error.length) { %>
        <div class="panel error-message"><%= error.join(' ') %></div>
      <% } %>

      <!-- 방/로비 분기 패널 -->
      <% if (isLobby) { %>
        <!-- 로비: 방 만들기 + 초대코드로 입장 -->
        <div class="panel room-actions">
          <h3>팀방</h3>
          <form action="/room/create" method="POST" class="room-form">
            <input type="text" name="name" placeholder="방 이름 (선택)" maxlength="30" />
            <button type="submit" class="btn-primary">방 만들기</button>
          </form>
          <form action="/room/join" method="POST" class="room-form">
            <input type="text" name="code" placeholder="초대코드 6자리" maxlength="6" required />
            <button type="submit" class="btn-secondary">코드로 입장</button>
          </form>
        </div>
      <% } else { %>
        <!-- private 방: 초대코드 표시 + 나가기 -->
        <div class="panel room-actions">
          <h3>초대코드</h3>
          <div class="invite-code"><%= room.invite_code %></div>
          <p class="hint">이 코드를 팀원에게 공유하세요.</p>
          <form action="/room/leave" method="POST"
                onsubmit="return confirm('방에서 나가 로비로 돌아갈까요?');">
            <button type="submit" class="btn-secondary">방 나가기</button>
          </form>
        </div>
      <% } %>

      <!-- 방 인원 목록 (private 방 전용, 4초 폴링으로 갱신) -->
      <% if (!isLobby) { %>
        <div class="panel">
          <div class="panel-row">
            <span class="panel-label">방 인원</span>
            <span class="panel-value">
              <span id="member-count"><%= members.length %></span> / <%= room.capacity %>명
            </span>
          </div>
          <ul class="member-list" id="member-list"
              data-host-id="<%= room.host_user_id || '' %>">
            <% members.forEach(function (m) { %>
              <li class="member-item <%= m.isMe ? 'me' : '' %>">
                <span class="member-emoji"><%= m.emoji %></span>
                <span class="member-nick"><%= m.nickname %></span>
                <% if (m.id === room.host_user_id) { %>
                  <span class="member-host">방장</span>
                <% } %>
                <% if (m.isMe) { %><span class="member-you">나</span><% } %>
              </li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <!-- 내 캐릭터 + 시작/종료 -->
      <div class="panel my-panel">
        <div class="my-character">
          <div class="my-emoji">
            <img class="sprite-img" src="<%= me.imagePath %>" alt=""
                 onerror="this.style.display='none';this.nextElementSibling.style.display='inline-block'" />
            <span class="sprite-emoji" style="display:none"><%= me.emoji %></span>
          </div>
          <div class="my-info">
            <div class="my-nick"><%= me.nickname %></div>
            <div class="my-character-name">
              <%= me.characterName ? me.characterName : '내 캐릭터' %>
            </div>
          </div>
        </div>
        <button id="btn-start" class="btn-primary" disabled>
          공부 시작하기
        </button>
        <button id="btn-end" class="btn-secondary" style="display: none;">
          공부 종료
        </button>
        <p class="hint">상태: <span id="status">대기</span></p>
        <p class="hint">경과 시간: <span id="elapsed">00:00:00</span></p>
        <p class="hint" id="seat-hint">좌석을 먼저 선택하세요.</p>
      </div>

      <!-- 알 부화 진행도 -->
      <div class="panel">
        <h3>부화 진행도</h3>
        <% var pct = egg.required > 0 ? Math.min(100, Math.floor((egg.progress / egg.required) * 100)) : 0; %>
        <div class="progress">
          <div class="progress-fill" id="egg-fill" style="width: <%= pct %>%"></div>
        </div>
        <p class="progress-text" id="egg-text">
          <%= Math.floor(egg.progress / 60) %>분 / <%= Math.floor(egg.required / 60) %>분
          (<%= pct %>%)
        </p>
      </div>

      <!-- 오늘의 기록 -->
      <div class="panel">
        <h3>오늘의 기록</h3>
        <div class="panel-row">
          <span class="panel-label">오늘 공부</span>
          <span class="panel-value"><%= today.minutes %>분</span>
        </div>
        <div class="panel-row">
          <span class="panel-label">오늘 세션</span>
          <span class="panel-value"><%= today.sessions %>회</span>
        </div>
        <div class="panel-row">
          <span class="panel-label">누적 공부</span>
          <span class="panel-value"><%= me.totalMinutes %>분</span>
        </div>
      </div>
    </aside>
  </main>
   <!--! scripts: socket.io, room.js, timer.js-->
  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/room.js"></script>
  <script src="/js/timer.js"></script>
</body>
</html>
