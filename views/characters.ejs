<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>내 도감 - Study Village</title>
  <!--* 0.3v 추가: 카드에 data-character-id(연출 대상 찾기용) + 부화 폭죽 스크립트 -->
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="village-bg">
  <header class="page-header">
    <h1>내 도감</h1>
    <nav>
      <a href="/">메인</a>
      <a href="/room">학습방</a>
      <a href="/records">내 기록</a>
    </nav>
  </header>

  <section class="panel">
    <h2>진행도 <%= dex.percent %>% (<%= dex.owned %> / <%= dex.total %>)</h2>
    <div class="progress">
      <div class="progress-fill" style="width: <%= dex.percent %>%"></div>
    </div>
  </section>

  <section class="character-grid">
    <% characters.forEach(function (c) { %>
      <div class="character-card <%= c.owned ? 'owned' : 'locked' %>" data-character-id="<%= c.id %>">
        <div class="character-sprite">
          <img class="sprite-img" src="<%= c.image_path %>" alt="<%= c.name %>"
               onerror="this.style.display='none';this.nextElementSibling.style.display='inline-block'" />
          <span class="sprite-emoji" style="display:none"><%= c.emoji %></span>
        </div>
        <div class="character-name"><%= c.owned ? c.name : '???' %></div>
        <div class="character-rarity rarity-<%= c.rarity %>"><%= c.rarity %></div>
      </div>
    <% }); %>
  </section>

  <!--! 부화 축하 연출: 폭죽(canvas-confetti) + 캐릭터 카드 해금 -->
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
  <script src="/js/characters.js"></script>
</body>
</html>
